# Copy to .env and fill in your values:  cp .env.example .env
# .env is gitignored — never commit real credentials.

# ── PersonalS3 connection (required) ───────────────────────────────
# Your self-hosted PersonalS3 S3-compatible endpoint, and a bucket you own.
PS3_HOST=https://your-personals3.example/api
PS3_BUCKET=name-of-backup-bucket

# SigV4 credentials for that PersonalS3 user (access key + secret key).
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# ── Optional (defaults shown; uncomment to override) ───────────────
# Object key template — content-addressed by sha256.
# S3_KEY=photos/{}

# Local SQLite index file.
# PICLOCKER_DB=piclocker.db

# Near-duplicate handling: "keep" (upload both) or "discard" (link, no upload),
# and the max pHash Hamming distance counted as a near-duplicate.
# PICLOCKER_NEAR_DUP_POLICY=keep
# PICLOCKER_NEAR_DUP_THRESHOLD=5

# CLIP model used for embeddings + text search.
# PICLOCKER_MODEL=sentence-transformers/clip-ViT-B-32

# Concurrent upload threads during ingest.
# PICLOCKER_UPLOAD_WORKERS=8
